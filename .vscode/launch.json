{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "attach",
            "name": "attach - remote",
            "address": "localhost",
            "port": 48132,
            "restart": true,
            "sourceMaps": true,
            "remoteRoot": "/app",
            "localRoot": "${workspaceFolder}",
            "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**"]
        }
    ]
}