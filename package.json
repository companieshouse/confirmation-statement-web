{
  "name": "confirmation-statement-web",
  "version": "0.0.1",
  "description": "Web front end for Confirmation Statement service",
  "main": "app.ts",
  "engines": {
    "node": ">=24.0.0",
    "npm": "^10"
  },
  "scripts": {
    "start": "node dist/bin/www.js",
    "build": "tsc && cp -r views locales dist/",
    "chs-dev": "nodemon --legacy-watch",
    "test": "jest",
    "lint": "eslint '{src,test}/**/*'",
    "lint:fix": "eslint '{src,test}/**/*' --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "sonarqube-base-branch": "sonar-scanner",
    "sonarqube-pull-request": "sonar-scanner -D sonar.pullrequest.base=main",
    "sonarqube": "branch=$(git rev-parse --symbolic-full-name --abbrev-ref HEAD); if [[ $branch == \"HEAD\" ]]; then echo $branch && npm run sonarqube-base-branch; else echo $branch && npm run sonarqube-pull-request; fi;",
    "coverage": "jest --coverage --passWithNoTests",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,json}": ["prettier --write"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/companieshouse/confirmation-statement-web.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/companieshouse/confirmation-statement-web/issues"
  },
  "homepage": "https://github.com/companieshouse/confirmation-statement-web#readme",
  "dependencies": {
    "@companieshouse/api-sdk-node": "2.0.358",
    "@companieshouse/ch-node-utils": "^2.1.13",
    "@companieshouse/node-session-handler": "~5.2.14",
    "@companieshouse/structured-logging-node": "^2.0.13",
    "@companieshouse/web-security-node": "^4.4.20",
    "@eslint/js": "^10.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/baggage-span-processor": "^0.5.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/otlp-exporter-base": "^0.218.0",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "accessible-autocomplete": "^3.0.1",
    "axios": "^1.17.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.22.2",
    "govuk-frontend": "5.14.0",
    "js-yaml": "^4.2.0",
    "luxon": "^3.7.2",
    "nunjucks": "^3.2.4",
    "private-api-sdk-node": "github:companieshouse/private-api-sdk-node#1.0.125",
    "sass": "^1.100.0",
    "uuid": "^11.1.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/jest": "^27.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/nunjucks": "^3.2.6",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.14",
    "npm-force-resolutions": "^0.0.10",
    "prettier": "^3.8.4",
    "sonarqube-scanner": "^4.3.6",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "axios": "^1.17.0",
    "protobufjs": "8.5.0"
  }
}
