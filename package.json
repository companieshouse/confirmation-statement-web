{
  "name": "confirmation-statement-web",
  "version": "0.0.1",
  "description": "Web front end for Confirmation Statement service",
  "main": "app.ts",
  "engines": {
    "node": ">=24.0.0",
    "npm": "^10"
  },
  "scripts": {
    "start": "node dist/bin/www.js",
    "build": "tsc && cp -r views locales dist/",
    "chs-dev": "nodemon --legacy-watch",
    "test": "jest",
    "lint": "eslint '{src,test}/**/*'",
    "lint:fix": "eslint '{src,test}/**/*' --fix",
    "sonarqube-base-branch": "sonar-scanner",
    "sonarqube-pull-request": "sonar-scanner -D sonar.pullrequest.base=main",
    "sonarqube": "branch=$(git rev-parse --symbolic-full-name --abbrev-ref HEAD); if [[ $branch == \"HEAD\" ]]; then echo $branch && npm run sonarqube-base-branch; else echo $branch && npm run sonarqube-pull-request; fi;",
    "coverage": "jest --coverage --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/companieshouse/confirmation-statement-web.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/companieshouse/confirmation-statement-web/issues"
  },
  "homepage": "https://github.com/companieshouse/confirmation-statement-web#readme",
  "dependencies": {
    "@companieshouse/api-sdk-node": "2.0.340",
    "@companieshouse/ch-node-utils": "^3.0.2",
    "@companieshouse/node-session-handler": "~5.2.12",
    "@companieshouse/structured-logging-node": "^2.0.11",
    "@companieshouse/web-security-node": "^4.4.18",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/otlp-exporter-base": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "accessible-autocomplete": "^3.0.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "govuk-frontend": "6.1.0",
    "js-yaml": "^4.1.1",
    "luxon": "^3.7.2",
    "nunjucks": "^3.2.4",
    "private-api-sdk-node": "github:companieshouse/private-api-sdk-node#1.0.121",
    "sass": "^1.99.0",
    "uuid": "^14.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.7.1",
    "@types/nunjucks": "^3.2.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "npm-force-resolutions": "^0.0.10",
    "sonarqube-scanner": "^4.3.6",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
